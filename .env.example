# LLM provider: anthropic | openai | gemini | groq
REPOSITION_LLM_PROVIDER=gemini

# API key for your chosen provider (only one is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# E2B sandbox key (free tier available)
E2B_API_KEY=

# GitHub token (repo scope required to open PRs)
GITHUB_TOKEN=

# Optional: default repo for opening PRs
# Can also be passed at runtime with --pr-repo flag
# GITHUB_PR_REPO=owner/repo
